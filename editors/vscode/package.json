{
  "name": "lemon-lang",
  "displayName": "Lemon (citrusquant)",
  "description": "Syntax highlighting and language server support for the lemon strategy DSL.",
  "version": "0.1.0",
  "publisher": "citrusquant",
  "license": "MIT",
  "icon": "icon.png",
  "keywords": [
    "lemon",
    "dsl",
    "trading",
    "backtesting",
    "strategy"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/citrusquant/citrusquant",
    "directory": "editors/vscode"
  },
  "homepage": "https://github.com/citrusquant/citrusquant/tree/main/editors/vscode#readme",
  "bugs": {
    "url": "https://github.com/citrusquant/citrusquant/issues"
  },
  "qna": false,
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:lemon"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "lemon",
        "aliases": [
          "Lemon",
          "lemon"
        ],
        "extensions": [
          ".lemon"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lemon",
        "scopeName": "source.lemon",
        "path": "./syntaxes/lemon.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Lemon",
      "properties": {
        "lemon.server.path": {
          "type": "string",
          "default": "lemon-lsp",
          "description": "Path to the lemon-lsp language server executable. Defaults to `lemon-lsp` on PATH (built with `cargo install --path crates/lemon-lsp`)."
        },
        "lemon.server.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the lemon language server (hover, completion, diagnostics). Disable to use syntax highlighting only."
        },
        "lemon.server.autoDownload": {
          "type": "boolean",
          "default": true,
          "description": "When lemon-lsp is not found on PATH, download the matching prebuilt binary from GitHub Releases and cache it. Disable to require a manually installed server (see lemon.server.path)."
        },
        "lemon.series": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Known data-series names for your engine (e.g. [\"close\", \"pe\", \"market_cap\"]). When set, the server flags unknown/typo'd series with did-you-mean suggestions. Leave empty to skip that check."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run check-types && node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check-types": "tsc --noEmit",
    "package": "npx @vscode/vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  }
}
