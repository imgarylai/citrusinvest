{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    "schedule:weekly"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Arrow + Parquet must share one major (dual versions break Array traits)",
      "matchPackageNames": [
        "parquet",
        "arrow-array",
        "arrow-cast",
        "arrow-schema",
        "arrow-buffer",
        "arrow-data",
        "arrow-select",
        "arrow-ord",
        "arrow-ipc",
        "arrow"
      ],
      "groupName": "arrow + parquet",
      "groupSlug": "arrow-parquet"
    }
  ]
}
