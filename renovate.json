{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    "schedule:weekly"
  ],
  "labels": ["dependencies"],
  "prConcurrentLimit": 6,
  "prHourlyLimit": 4,
  "lockFileMaintenance": {
    "enabled": true
  },
  "ignorePaths": [
    "**/node_modules/**",
    "**/dist/**",
    "crates/**/pkg/**"
  ],
  "packageRules": [
    {
      "description": "Automerge non-major updates (minor + patch) once CI is green; majors stay manual",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Apache Arrow + Parquet must share one major — dual arrow_array versions break Array trait resolution (see #92–#95 / #114)",
      "matchDatasources": ["crate"],
      "matchPackageNames": ["/^arrow(-|$)/", "parquet"],
      "groupName": "arrow + parquet",
      "groupSlug": "arrow-parquet"
    },
    {
      "description": "Astro core + official @astrojs/* integrations move together on majors",
      "matchDatasources": ["npm"],
      "matchPackageNames": ["astro", "/^@astrojs//"],
      "groupName": "astro monorepo",
      "groupSlug": "astro-monorepo"
    },
    {
      "description": "CodeMirror packages are version-coupled; bump as one group",
      "matchDatasources": ["npm"],
      "matchPackageNames": ["/^@codemirror//", "/^@lezer//"],
      "groupName": "codemirror",
      "groupSlug": "codemirror"
    },
    {
      "description": "Published by this repo's wasm release workflow — not Renovate",
      "matchDatasources": ["npm"],
      "matchPackageNames": ["/^@citrusquant//"],
      "enabled": false
    }
  ]
}
