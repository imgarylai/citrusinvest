---
// Self-contained interactive backtest widget. The heavy lifting (WASM load,
// run, chart) lives in ./playground.ts, loaded client-side only.
const initial = `# Hold whichever names have the highest 2-day average close.
# Edit this and press Run (or Ctrl/Cmd+Enter).
is_largest(sma(close, 2), 3)`;
---

<div class="pg-wrap not-content" data-playground>
  <div>
    <label for="pg-src" style="font-weight:600;font-size:0.85rem;">Strategy (lemon DSL)</label>
    <textarea id="pg-src" class="pg-editor" spellcheck="false">{initial}</textarea>
    <button class="pg-run" type="button">▶ Run backtest</button>
    <p class="pg-status" data-kind="info">Ready. Runs entirely in your browser on a synthetic sample dataset.</p>
  </div>
  <div>
    <canvas class="pg-chart" aria-label="Equity curve"></canvas>
    <div class="pg-metrics"></div>
  </div>
</div>

<script>
  import { initPlayground } from './playground.ts';
  document.querySelectorAll<HTMLElement>('[data-playground]').forEach((el) => initPlayground(el));
</script>
